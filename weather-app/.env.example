# ============================================================
# NOTA: Este es un archivo de EJEMPLO (.env.example)
# ============================================================
# Crea un archivo .env en la raíz del proyecto con tus valores reales
# NO COMITEES .env a control de versiones - está en .gitignore
# ============================================================

# ============================================================
# API CONFIGURATION
# ============================================================
# Open-Meteo API URLs (públicos, sin autenticación requerida)
API_BASE_URL=https://api.open-meteo.com
GEOCODING_API_URL=https://geocoding-api.open-meteo.com

# Timeout para solicitudes API (en segundos)
API_TIMEOUT=5

# Número de reintentos para solicitudes fallidas
API_RETRIES=3

# IMPORTANTE: Reemplaza esto con tus claves de API si usas otros servicios
# Ejemplo:
# API_KEY=tu_clave_api_aqui_no_la_compartas_nunca
API_KEY=

# ============================================================
# FLASK CONFIGURATION
# ============================================================
# Entorno: development, testing, production
FLASK_ENV=development

# Habilitar modo debug (NUNCA en producción)
FLASK_DEBUG=False

# Puerto para el servidor Flask
FLASK_PORT=5000

# IMPORTANTE: Genera una clave segura para producción
# Puedes usar: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=dev-key-change-in-production

# ============================================================
# OUTPUT CONFIGURATION
# ============================================================
# Formato de salida: 'detailed' o 'simple'
OUTPUT_FORMAT=detailed

# ============================================================
# CACHE CONFIGURATION
# ============================================================
# Habilitar caché de datos API
CACHE_ENABLED=True

# Duración del caché en segundos (600 = 10 minutos)
CACHE_DURATION=600

# ============================================================
# LOGGING CONFIGURATION
# ============================================================
# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Archivo de log
LOG_FILE=weather_app.log

# ============================================================
# EJEMPLOS DE CONFIGURACIÓN PARA OTROS SERVICIOS
# ============================================================
# Si integras otras APIs, agrega aquí sus claves:
# 
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WEATHER_API_KEY=tu_clave_aqui
# DATABASE_URL=postgresql://user:password@localhost/dbname
# JWT_SECRET=tu_secreto_jwt_aqui
